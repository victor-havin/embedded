void UIComposer::receive(const Subscription& subscription, UIEvent& event) {
    max_queue_len = std::max(max_queue_len, get_length());

    switch(event.id) {
        // --- PHASE 1: Low-Level System Touches (Process State Matrix) ---
        case UIEvent::EVT_TOUCH_DOWN:
        case UIEvent::EVT_TOUCH_UP:
        case UIEvent::EVT_TOUCH_DRAG:
        {
            Variant::Point point = event.get_variant().get_point();
            
            // Map instantaneous hardware state flags
            bool is_down = (event.id == UIEvent::EVT_TOUCH_DOWN || event.id == UIEvent::EVT_TOUCH_DRAG);
            bool was_down = last_touch_state_was_down; // Persistent UIComposer member boolean flag

            // Single linear pass over your pre-flattened component list.
            // NO dynamic vector allocations, NO heap churning, NO memory fragmentation.
            for (Component* comp : flat_components) {
                if (!comp) continue;

                // 1. Evaluate geometry directly on the fly via parent traversal
                bool is_inside = comp->is_point_inside_absolute(point);

                // 2. Pack parameters into the ultra-fast 3-bit matrix lookup index token
                // Bit 2: Was Finger Down | Bit 1: Is Finger Down | Bit 0: Is Point Inside Bounding Box
                uint8_t token = ((was_down ? 1 : 0) << 2) | ((is_down ? 1 : 0) << 1) | (is_inside ? 1 : 0);

                // 3. Perform the O(1) table transition lookup
                CompState current_state = comp->get_touch_state();
                Transition t = StateTable[static_cast<uint8_t>(current_state)][token];

                // 4. Fire the component's translated output action callback if one is mapped
                if (t.action != nullptr) {
                    (this->*(t.action))(comp, point);
                }

                // 5. Apply the next deterministic state boundary cell
                comp->set_touch_state(t.next_state);
            }

            // Lock physical frame tracking history state for next polling step
            last_touch_state_was_down = is_down;
            break;
        }

        // --- PHASE 2: Translated Component Outputs (Deliver to Subscribers) ---
        case UIEvent::EVT_ENTER:
        case UIEvent::EVT_LEAVE:
        case UIEvent::EVT_PRESS:
        case UIEvent::EVT_RELEASE:
        {
            auto callback = subscription.get_callback();
            if (subscription.get_flags() & UIComposer::SUB_SELF) {
                if (subscription.get_subscriber() == event.get_source()) {
                    callback(subscription, event);
                }
            } else {
                callback(subscription, event);
            }
            break;
        }
    }
}

void UIComposer::do_press(Component* comp, Variant::Point pt) {
    UIEvent ev(UIEvent::EVT_PRESS, pt);
    ev.set_source(comp);
    this->dispatch_translated_event(ev); 
}

void UIComposer::do_release(Component* comp, Variant::Point pt) {
    UIEvent ev(UIEvent::EVT_RELEASE, pt);
    ev.set_source(comp);
    this->dispatch_translated_event(ev);
}

void UIComposer::do_enter(Component* comp, Variant::Point pt) {
