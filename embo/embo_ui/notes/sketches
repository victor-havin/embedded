Variant::Point Component::get_absolute_position() const {
    Variant::Point abs_p = position.p; // Start with local relative coordinates
    Component* parent_ptr = parent;

    // Walk up the family tree until we hit a top-level container or the root
    while (parent_ptr != nullptr) {
        abs_p.x += parent_ptr->position.p.x;
        abs_p.y += parent_ptr->position.p.y;
        parent_ptr = parent_ptr->parent;
    }
    return abs_p;
}

bool Component::is_point_inside_absolute(Variant::Point pt) const {
    Variant::Point abs_p = get_absolute_position();
    // Direct, on-the-fly four-integer boundary math check
    return (pt.x >= abs_p.x && 
            pt.x <  abs_p.x + position.s.w &&
            pt.y >= abs_p.y && 
            pt.y <  abs_p.y + position.s.h);
}

