    this->dispatch_translated_event(ev);
}

void UIComposer::dispatch_translated_event(UIEvent& ev) {
    // Deliver the newly created lifecycle event directly to matching subscriptions
    for (const auto& sub : subscriptions[ev.id]) {
        this->receive(sub, ev); 
    }
}

void setup_hardware_timer() {
    // Configure hardware timer 0 to fire every 1000 microseconds (1ms)
    // ESP32-specific syntax shown here; adapts easily to other chips
    hw_timer_t* timer = timerBegin(0, 80, true); // 80MHz prescaler -> 1 tick = 1 microsecond
    timerAttachInterrupt(timer, &on_1ms_timer_tick, true);
    timerAlarmWrite(timer, 1000, true); // 1000 microseconds = 1ms, auto-reload = true
    timerAlarmEnable(timer);
}